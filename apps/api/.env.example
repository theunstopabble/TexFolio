# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb+srv://your-mongodb-username:your-mongodb-password@your-cluster.mongodb.net/texfolio

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_your_clerk_secret_key

# CORS (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# AI API Keys (use one or more)
GROQ_API_KEY=your-groq-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
NVIDIA_API_KEY=your-nvidia-api-key

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Brevo Email Service
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=no-reply@yourdomain.com

# LaTeX Configuration
USE_DOCKER_LATEX=true